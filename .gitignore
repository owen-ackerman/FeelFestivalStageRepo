# Large 3D assets and stage design files — not meant for git
Stage3DFiles/

# Large 3D mesh formats anywhere in the repo (RibbonSimulation etc.)
*.fbx
*.obj
*.mtl
*.3dm

# TouchDesigner .toe project files -- binaries that balloon to 100s of MB
# once geometry/media is imported (WaveMotorController.toe hit 172MB). The
# version-controlled source is the Python in extensions/ and dats/; the .toe
# lives on disk / OneDrive, not git.
*.toe

# TouchDesigner autosave backup increments
**/Backup/

# TouchDesigner import cache
**/TDImportCache/

# Local Claude Code tool config (machine-specific, not project source)
.claude/settings.local.json

# Python bytecode cache
__pycache__/
*.pyc
